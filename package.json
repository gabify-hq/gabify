{
  "name": "gabify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "worker:email": "tsx --env-file=.env.local src/queues/email-sync.worker.ts",
    "worker:documents": "tsx --env-file=.env.local src/queues/document-parse.worker.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "dev:all": "concurrently --names \"next,email,docs,studio\" --prefix-colors \"blue,green,yellow,magenta\" \"npm run dev\" \"npm run worker:email\" \"npm run worker:documents\" \"npm run db:studio\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:bootstrap": "tsx --env-file=.env.local scripts/seed-office.ts",
    "gate": "node scripts/gate.mjs",
    "toconline:types": "openapi-typescript integrations/toconline/openapi.json -o integrations/toconline/types.ts",
    "worker:toconline": "tsx --env-file=.env.local src/queues/toconline.worker.ts",
    "worker:moloni": "tsx --env-file=.env.local src/queues/moloni.worker.ts",
    "worker:invoicexpress": "tsx --env-file=.env.local src/queues/invoicexpress.worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@base-ui/react": "^1.5.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "adm-zip": "^0.5.17",
    "bullmq": "^5.77.6",
    "canvas": "^3.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "file-type": "^22.0.1",
    "googleapis": "^173.0.0",
    "imap": "^0.8.19",
    "ioredis": "^5.11.0",
    "jose": "^6.2.3",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.17.0",
    "mailparser": "^3.9.9",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "shadcn": "^4.8.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3",
    "zxing-wasm": "^3.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "vitest-mock-extended": "^4.0.0"
  },
  "overrides": {
    "nodemailer": "^9.0.1",
    "hono": "^4.12.25",
    "vite": "^8.0.16",
    "esbuild": "^0.28.1",
    "@hono/node-server": "^1.19.13",
    "js-yaml": "^4.1.2",
    "postcss": "^8.5.10",
    "utf7": {
      "semver": "^5.7.2"
    }
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "prisma@7.8.0": true,
    "unrs-resolver@1.12.2": true,
    "sharp@0.34.5": true,
    "esbuild@0.28.0": true,
    "esbuild@0.28.1": true,
    "msgpackr-extract@3.0.4": true,
    "msw@2.14.6": true,
    "canvas@3.2.3": true
  }
}
