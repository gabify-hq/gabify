# ─────────────────────────────────────────
# Gabify — Environment Variables
# Copy to .env.local for local development
# ─────────────────────────────────────────

# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here   # openssl rand -base64 32

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/gabify

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# ─── Cloudflare R2 ───
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=gabify-attachments

# ─── Resend (outbound email / magic links) ───
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=no-reply@gabify.pt

# ─── Anthropic (Claude AI) ───
ANTHROPIC_API_KEY=sk-ant-your-api-key
CLAUDE_MODEL=claude-sonnet-4-5   # optional override

# ─── Microsoft Graph API (Outlook/Microsoft 365) ───
# Register app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Required permissions: Mail.Read, Mail.Send, Mail.ReadWrite (delegated)
AZURE_AD_CLIENT_ID=your-app-client-id
AZURE_AD_CLIENT_SECRET=your-app-client-secret
AZURE_AD_TENANT_ID=common   # or specific tenant ID
GRAPH_WEBHOOK_SECRET=your-hmac-secret-for-webhook-validation

# ─── Gmail API ───
# Register app at: https://console.cloud.google.com/
# Enable: Gmail API, Cloud Pub/Sub API
# Required scopes: gmail.readonly, gmail.send, gmail.modify
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gabify-gmail

# ─── Encryption (for OAuth token storage) ───
TOKEN_ENCRYPTION_KEY=your-64-hex-char-key   # node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
