# ─────────────────────────────────────────
# Gabify — Environment Variables
# Copy to .env.local for local development
# ─────────────────────────────────────────

# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here   # openssl rand -base64 32
AUTH_SECRET=your-secret-here       # Auth.js v5 (same value as NEXTAUTH_SECRET works)

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/gabify
# Test database used by the acceptance suite (optional — defaults to gabify_test on localhost)
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/gabify_test

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# ─── Cloudflare R2 ───
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=gabify-attachments

# ─── Resend (outbound email / magic links / invitations) ───
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=no-reply@gabify.pt

# ─── Anthropic (Claude AI) ───
ANTHROPIC_API_KEY=sk-ant-your-api-key
CLAUDE_MODEL=claude-sonnet-4-5   # optional override

# ─── Microsoft Graph API (Outlook/Microsoft 365) ───
# Register app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Required permissions: Mail.Read, Mail.Send, Mail.ReadWrite (delegated)
MICROSOFT_CLIENT_ID=your-app-client-id
MICROSOFT_CLIENT_SECRET=your-app-client-secret
AZURE_AD_TENANT_ID=common   # or specific tenant ID
# REQUIRED for webhooks — the Graph webhook refuses requests (503) without it (fail-closed)
GRAPH_WEBHOOK_SECRET=your-secret-for-webhook-clientstate-validation

# ─── Gmail API ───
# Register app at: https://console.cloud.google.com/
# Enable: Gmail API, Cloud Pub/Sub API
# Required scopes: gmail.readonly, gmail.send, gmail.modify
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gabify-gmail
# Audience expected in the Google-signed JWT of Pub/Sub push requests
GMAIL_WEBHOOK_URL=https://your-domain/api/webhooks/gmail

# ─── Email sync ───
# Polling interval for the email-sync worker (milliseconds)
EMAIL_POLL_INTERVAL_MS=30000

# ─── Rate limits (per class — ADDENDUM A11; defaults shown) ───
RATE_LIMIT_API_PER_HOUR=600
RATE_LIMIT_MAGIC_LINK_PER_HOUR=5
RATE_LIMIT_WEBHOOK_PER_MIN=120
RATE_LIMIT_UPLOAD_USER_PER_HOUR=60
RATE_LIMIT_UPLOAD_OFFICE_PER_HOUR=300
RATE_LIMIT_INGEST_PER_HOUR=100
# Portal do cliente final (fase P1) — utilizadores externos, limites por minuto
RATE_LIMIT_CLIENT_API_PER_MIN=30
RATE_LIMIT_CLIENT_UPLOAD_PER_MIN=10

# ─── Encryption (for OAuth token storage) ───
TOKEN_ENCRYPTION_KEY=your-64-hex-char-key   # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── Bootstrap (first office + owner — npm run seed:bootstrap) ───
BOOTSTRAP_OWNER_EMAIL=owner@gabinete.pt
BOOTSTRAP_OFFICE_NAME=Gabinete Principal
BOOTSTRAP_OWNER_NAME=Nome do Dono

# ─── Assistente de perguntas (read-only Q&A — feature/gabify-assistant) ───
# Modelo económico para o chat de perguntas; Haiku por omissão.
ASSISTANT_MODEL=claude-haiku-4-5-20251001
RATE_LIMIT_ASSISTANT_PER_MIN=20

# ── TOConline integration (pull) ──
# Interval of the repeatable sales-pull scan (ms). Default: 30 minutes.
TOCONLINE_PULL_INTERVAL_MS=1800000

# ─── Moloni (fonte — pull de faturas emitidas; feature/moloni-source) ───
# Credenciais de developer da app Gabify (Área de Cliente Moloni).
# Usadas pelo slice de integração pós-merge (job moloni-pull) — o connector
# em si recebe-as por parâmetro. Ver HANDOFF_MOLONI.md.
MOLONI_CLIENT_ID=your-moloni-developer-id
MOLONI_CLIENT_SECRET=your-moloni-client-secret
# Repeatable moloni-pull scan interval (ms) — default 30 min. Worker: worker:moloni.
MOLONI_PULL_INTERVAL_MS=1800000

# ─── InvoiceXpress source connector (feature/invoicexpress-source) ───
# Only needed for the human validation checklist (HANDOFF_IVX.md) — the
# connector itself takes credentials per call, nothing reads these at runtime.
# Account name = subdomain of https://ACCOUNT_NAME.app.invoicexpress.com
# API key: https://www.app.invoicexpress.com/users/api
# INVOICEXPRESS_ACCOUNT_NAME=your-account-name
# INVOICEXPRESS_API_KEY=your-api-key
# Repeatable invoicexpress-pull scan interval (ms) — default 30 min. Worker: worker:invoicexpress.
INVOICEXPRESS_PULL_INTERVAL_MS=1800000

# ─── Demo seed (npm run seed:demo) ───
# SEED_DEMO_OWNER_EMAIL=demo@gabify.local
# SEED_DEMO_FORCE=true   # only to force-run with NODE_ENV=production
